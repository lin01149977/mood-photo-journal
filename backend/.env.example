# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
# Demo (default): sqlite, single file, zero-setup. Tables auto-created on boot.
DB_DIALECT=sqlite
DB_SQLITE_FILE=./data/dev.db

# Production: switch to postgres and run `npm run db:migrate` before `npm start`.
# DB_DIALECT=postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/vibecoding
